# =========================================================================
# FRONTEND CONFIGURATION (.env.local in /frontend)
# =========================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =========================================================================
# BACKEND CONFIGURATION (.env in /backend)
# =========================================================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google OAuth credentials (if validating backend side)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# Email service via Gmail SMTP
GMAIL_SENDER_EMAIL=your-gmail-sender-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-16-character-app-password

# Flask application configurations
FLASK_SECRET_KEY=generate-a-secure-random-secret-key-for-sessions
FLASK_ENV=development
FRONTEND_URL=http://localhost:3000
PORT=5000
