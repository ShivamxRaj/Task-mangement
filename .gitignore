# Root gitignore to exclude environment variables, dependencies, caches, and builds

# Local environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env.local

# Python caches and virtual environments
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.ipynb_checkpoints

# Node / Next.js builds and dependencies
node_modules/
frontend/node_modules/
.next/
frontend/.next/
out/
build/
dist/

# IDE / System files
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
thumbs.db
db.sqlite3
